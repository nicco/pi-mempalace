{
  "name": "mempalace-pi",
  "version": "0.2.4",
  "description": "MemPalace extension package for pi, adding commands, tools, and save reminders for memory workflows.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "mempalace",
    "memory",
    "rag"
  ],
  "homepage": "https://github.com/juhas96/mempalace-pi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/juhas96/mempalace-pi.git"
  },
  "bugs": {
    "url": "https://github.com/juhas96/mempalace-pi/issues"
  },
  "files": [
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-ai": {
      "optional": true
    },
    "@mariozechner/pi-coding-agent": {
      "optional": true
    },
    "@sinclair/typebox": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
